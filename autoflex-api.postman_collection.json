{
  "info": {
    "_postman_id": "autoflex-api-collection",
    "name": "Autoflex API",
    "description": "Complete API collection for Autoflex - Product and Raw Material Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0-SNAPSHOT"
  },
  "item": [
    {
      "name": "Product",
      "description": "Product catalog management",
      "item": [
        {
          "name": "List all products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Retrieve all products from the catalog"
          },
          "response": []
        },
        {
          "name": "Create a new product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mayo\",\n  \"value\": 12.5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Registers a product in the database and returns the generated ID."
          },
          "response": []
        },
        {
          "name": "Retrieve a product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Product ID"
                }
              ]
            },
            "description": "Get detailed information about a specific product"
          },
          "response": []
        },
        {
          "name": "Update an existing product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mayo Premium\",\n  \"value\": 15.0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Product ID"
                }
              ]
            },
            "description": "Update product information (name and/or value)"
          },
          "response": []
        },
        {
          "name": "Delete a product by ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Product ID"
                }
              ]
            },
            "description": "Remove a product from the catalog"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Product Composition",
      "description": "Manage the recipe/composition of products",
      "item": [
        {
          "name": "Add raw material to product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rawMaterialId\": 10,\n  \"quantity\": 2.5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/:productId/raw-materials",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":productId", "raw-materials"],
              "variable": [
                {
                  "key": "productId",
                  "value": "1",
                  "description": "Product ID"
                }
              ]
            },
            "description": "Links a raw material to a product with a specific quantity."
          },
          "response": []
        },
        {
          "name": "Update raw material quantity",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rawMaterialId\": 10,\n  \"quantity\": 3.0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/:productId/raw-materials/:rawMaterialId",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":productId", "raw-materials", ":rawMaterialId"],
              "variable": [
                {
                  "key": "productId",
                  "value": "1",
                  "description": "Product ID"
                },
                {
                  "key": "rawMaterialId",
                  "value": "10",
                  "description": "Raw Material ID"
                }
              ]
            },
            "description": "Updates the required quantity of a specific raw material in the product."
          },
          "response": []
        },
        {
          "name": "Remove raw material from product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:productId/raw-materials/:rawMaterialId",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":productId", "raw-materials", ":rawMaterialId"],
              "variable": [
                {
                  "key": "productId",
                  "value": "1",
                  "description": "Product ID"
                },
                {
                  "key": "rawMaterialId",
                  "value": "10",
                  "description": "Raw Material ID"
                }
              ]
            },
            "description": "Deletes the association between the product and the raw material."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Production Planning",
      "description": "Endpoints for production feasibility and suggestions",
      "item": [
        {
          "name": "Get production suggestion",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/production/suggestion",
              "host": ["{{baseUrl}}"],
              "path": ["production", "suggestion"]
            },
            "description": "Calculates producible quantity based on current stock, prioritizing higher-value products."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Raw Material",
      "description": "Raw material inventory management",
      "item": [
        {
          "name": "List all raw materials",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/raw-materials",
              "host": ["{{baseUrl}}"],
              "path": ["raw-materials"]
            },
            "description": "Retrieve all raw materials from inventory"
          },
          "response": []
        },
        {
          "name": "Create new raw material",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Steel Sheet\",\n  \"quantity\": 150\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/raw-materials",
              "host": ["{{baseUrl}}"],
              "path": ["raw-materials"]
            },
            "description": "Registers a raw material in stock."
          },
          "response": []
        },
        {
          "name": "Retrieve raw material by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/raw-materials/:id",
              "host": ["{{baseUrl}}"],
              "path": ["raw-materials", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "10",
                  "description": "Raw Material ID"
                }
              ]
            },
            "description": "Get detailed information about a specific raw material"
          },
          "response": []
        },
        {
          "name": "Update raw material",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Steel Sheet Grade A\",\n  \"quantity\": 200\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/raw-materials/:id",
              "host": ["{{baseUrl}}"],
              "path": ["raw-materials", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "10",
                  "description": "Raw Material ID"
                }
              ]
            },
            "description": "Update stock quantity or name."
          },
          "response": []
        },
        {
          "name": "Delete raw material",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/raw-materials/:id",
              "host": ["{{baseUrl}}"],
              "path": ["raw-materials", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "10",
                  "description": "Raw Material ID"
                }
              ]
            },
            "description": "Remove a raw material from inventory"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
